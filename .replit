modules = ["python-3.11"]

[nix]
channel = "stable-25_05"
packages = ["cargo", "glibcLocales", "libiconv", "libxcrypt", "openssl", "pkg-config", "postgresql", "rustc"]

[deployment]
deploymentTarget = "autoscale"
run = ["streamlit", "run", "app.py", "--server.port", "5000"]
build = ["sh", "-c", "pip install -r requirements_production.txt"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Telegram Bot"
author = "agent"
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python run_telegram_bot.py"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Production Bot"
author = 47714575
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python main_production.py"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Trading Dashboard"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Telegram Bot"

[[workflows.workflow]]
name = "Trading Dashboard"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python -m streamlit run app.py --server.port=5000 --server.address=0.0.0.0"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 5000
externalPort = 80

[agent]
expertMode = true
