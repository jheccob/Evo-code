modules = ["python-3.11"]

[nix]
channel = "stable-25_05"
packages = ["cargo", "glibcLocales", "libiconv", "libxcrypt", "openssl", "pkg-config", "postgresql", "rustc"]

[deployment]
deploymentTarget = "autoscale"
run = ["python", "-m", "streamlit", "run", "app.py", "--server.port", "5000", "--server.address"]
build = ["sh", "-c", "pip install -r requirements_production.txt"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Production Bot"
author = 47714575
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python main_production.py"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Trading Dashboard"

[[workflows.workflow]]
name = "Trading Dashboard"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python -m streamlit run app.py --server.port 5000 --server.address 0.0.0.0"
waitForPort = 5000

[[workflows.workflow]]
name = "Streamlit Dashboard"
author = 47788661
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python -m streamlit run app.py --server.port=8080 --server.address=0.0.0.0"

[[workflows.workflow]]
name = "Dashboard Principal"
author = 47788661
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python -m streamlit run app.py --server.port=8080 --server.address=0.0.0.0 --server.headless=true"

[[workflows.workflow]]
name = "Bot Telegram"
author = 47788661
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python run_telegram_bot.py"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 44735
externalPort = 3000

[agent]
expertMode = true
