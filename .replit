modules = ["python-3.11"]

[nix]
channel = "stable-25_05"
packages = ["glibcLocales"]

[deployment]
deploymentTarget = "autoscale"
run = ["sh", "-c", "python main_production.py"]
build = ["sh", "-c", "pip install -r requirements_production.txt"]

[workflows]
runButton = "Production Bot"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Streamlit Trading Dashboard"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "install_dependencies"

[[workflows.workflow]]
name = "Streamlit Trading Dashboard"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "streamlit run app.py --server.port 5000"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "install_dependencies"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "uv add ccxt plotly pandas numpy"

[[workflows.workflow]]
name = "Telegram Bot"
author = 47714575
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python start_telegram_bot.py"

[[workflows.workflow]]
name = "Production Bot"
author = 47714575
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python main_production.py"

[[ports]]
localPort = 5000
externalPort = 80
